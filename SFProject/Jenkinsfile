pipeline {
    agent any

    environment {
        SF_AUTH_URL = credentials('sf-auth-url')
    }

    stages {

        stage('Checkout From GitHub') {
            steps {
                checkout scm
            }
        }

        stage('Verify SF CLI') {
            steps {
                bat 'sf --version'
            }
        }

        stage('Authenticate Salesforce') {
            steps {
                bat '''
                echo %SF_AUTH_URL% > auth.txt

                sf org login sfdx-url ^
                --sfdx-url-file auth.txt ^
                --alias JenkinsOrg ^
                --set-default
                '''
            }
        }

        stage('Verify Org') {
            steps {
                bat 'sf org list'
            }
        }

        stage('Deploy Apex Classes') {
            steps {
                bat '''
                sf project deploy start ^
                --metadata ApexClass:JenkinsDemo ^
                --metadata ApexClass:JenkinsDemoTest ^
                --target-org yogi81102.3781dfe9b859@agentforce.com ^
                --test-level RunSpecifiedTests ^
                --tests JenkinsDemoTest ^
                --wait 60
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed'
        }
    }
}
